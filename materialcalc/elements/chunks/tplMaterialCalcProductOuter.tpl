<div class="materialcalc-box">
    <div class="materialcalc-box__title">Материалы</div>

    <ul class="materialcalc-list">
        [[+rows]]
    </ul>

    <div class="materialcalc-summary">
        <div class="materialcalc-summary__row">
            <span>Стоимость материалов</span>
            <b>[[+materials_total]] ₽</b>
        </div>

        [[+markup_html]]

        <div class="materialcalc-summary__row materialcalc-summary__row--total">
            <span>Расчётная цена</span>
            <b>[[+total_price]] ₽</b>
        </div>
    </div>
</div>